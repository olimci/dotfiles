# --- History ---
HISTFILE="${HOME}/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000
unsetopt SHARE_HISTORY
setopt INC_APPEND_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_SPACE
setopt HIST_VERIFY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_REDUCE_BLANKS
setopt HIST_IGNORE_DUPS
setopt HIST_SAVE_NO_DUPS
setopt EXTENDED_HISTORY

# --- Shell options ---
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt EXTENDED_GLOB
setopt NO_NOMATCH
setopt INTERACTIVE_COMMENTS
bindkey -e

if [[ -n "$HOMEBREW_PREFIX" && -r "$HOMEBREW_PREFIX/share/zsh-history-substring-search/zsh-history-substring-search.zsh" ]]; then
  source "$HOMEBREW_PREFIX/share/zsh-history-substring-search/zsh-history-substring-search.zsh"
fi

if command -v fzf >/dev/null 2>&1; then
  source <(fzf --zsh)
fi

if (( $+widgets[history-substring-search-up] )); then
  bindkey '^[[A' history-substring-search-up
  bindkey '^[[B' history-substring-search-down
else
  bindkey '^[[A' up-line-or-search
  bindkey '^[[B' down-line-or-search
fi

if (( $+widgets[fzf-history-widget] )); then
  bindkey '^R' fzf-history-widget
fi

bindkey '^[[1;5C' forward-word
bindkey '^[[1;5D' backward-word
bindkey '^[[3~' delete-char
bindkey '^[[H' beginning-of-line
bindkey '^[[F' end-of-line

# --- Completion ---
zmodload zsh/complist

ZSH_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
mkdir -p "$ZSH_CACHE_DIR"

autoload -Uz compinit
compinit -d "${ZSH_CACHE_DIR}/zcompdump-${ZSH_VERSION}-${HOST}"

# Nicer completion menus
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=** r:|=**'
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$ZSH_CACHE_DIR/zcompcache"
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' group-name ''
zstyle ':completion:*:descriptions' format '%F{yellow}-- %d --%f'
zstyle ':completion:*:messages' format '%F{purple}-- %d --%f'
zstyle ':completion:*:warnings' format '%F{red}-- no matches found --%f'
zstyle ':completion:*' verbose yes
zstyle ':completion:*' completer _complete _match _approximate
zstyle ':completion:*:approximate:*' max-errors 1 numeric

typeset -U path PATH

path=(
  "$HOME/.local/bin"
  "$HOME/bin"
  $path
)

if command -v zoxide >/dev/null 2>&1; then
  export _ZO_FZF_OPTS='--height=40% --layout=reverse --border --info=inline'
  export _ZO_RESOLVE_SYMLINKS=1
  eval "$(zoxide init zsh --cmd z --hook pwd)"
fi

if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

# --- fzf defaults ---
export FZF_DEFAULT_COMMAND='fd --type f --hidden --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_COMPLETION_TRIGGER='**'

# --- Aliases ---
alias l='eza --all --group-directories-first --icons=auto'
alias ls='eza --all --group-directories-first --icons=auto'
alias la='eza --all --long --header --group-directories-first --icons=auto'
alias ll='eza --all --long --header --git --group-directories-first --icons=auto'
alias lt='eza --tree --level=2 --group-directories-first --icons=auto'
alias lsa='ll'
alias ff='fastfetch'
alias ffs='fastfetch --config small'
alias sl='mpv --player-operation-mode=pseudo-gui --no-terminal ~/.config/.assets/sl'
alias cat='bat --style=plain --paging=never'
alias g='rg -n --smart-case'
alias zl='zoxide query --list --score'
alias icat='kitty +kitten icat'
alias kssh='kitty +kitten ssh'

e() {
  local -a editor_cmd

  if [[ -n "$VISUAL" ]]; then
    editor_cmd=(${(z)VISUAL})
  elif [[ -n "$EDITOR" ]]; then
    editor_cmd=(${(z)EDITOR})
  else
    editor_cmd=(vi)
  fi

  command "${editor_cmd[@]}" -- "$@"
}

sd() {
  local dir
  dir="$(
    fd --type d --hidden --follow --exclude .git . "$HOME" |
      sed "s#^$HOME/##" |
      fzf --preview='eza --tree --level=2 --icons=auto "$HOME/{}" 2>/dev/null | head -200'
  )" || return

  [[ -n "$dir" ]] && builtin cd -- "$HOME/$dir"
}

# --- Late hooks ---
if [[ -n "$HOMEBREW_PREFIX" ]] && [[ -r "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]]; then
  source "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi

function precmd() {
  if [[ -n "$_first_prompt_done" ]]; then
    print ""
  fi
  _first_prompt_done=1
}
