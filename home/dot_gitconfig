[core]
    pager = delta

[delta]
    navigate = true
    line-numbers = true
    side-by-side = true

[interactive]
    diffFilter = delta --color-only

[user]
    useConfigOnly = true
    name = Oli McInnes
    email = oli@mcinnes.cc

[url "ssh://git@github-olimci/"]
    insteadOf = git@github.com:
    insteadOf = ssh://git@github.com/

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[push]
    autoSetupRemote = true

[init]
	defaultBranch = main
