#!/bin/sh

status=${1:-0}
shift
cmdline=$*

[ -n "$cmdline" ] || exit 0

normalized=$cmdline

for prefix in command builtin exec env; do
    case "$normalized" in
        "$prefix "*) normalized=${normalized#"$prefix "};;
    esac
done

while :; do
    first_word=${normalized%% *}
    case "$first_word" in
        [A-Za-z_][A-Za-z0-9_]*=*)
            [ "$first_word" = "$normalized" ] && normalized= && break
            normalized=${normalized#"$first_word "}
            ;;
        *)
            break
            ;;
    esac
done

first_word=${normalized%% *}
program=${first_word##*/}

case "$program" in
    ssh|nvim|vim|vi|atuin)
        exit 0
        ;;
esac

if [ "$status" = "0" ]; then
    title="Command finished"
    icon="info"
    urgency="normal"
else
    title="Command failed ($status)"
    icon="error"
    urgency="critical"
fi

if command -v kitten >/dev/null 2>&1; then
    kitten_bin=$(command -v kitten)
else
    kitten_bin=/opt/homebrew/bin/kitten
fi

exec "$kitten_bin" notify \
    --app-name "kitty" \
    --type "command-finished" \
    --icon "$icon" \
    --urgency "$urgency" \
    "$title" \
    "$cmdline"
