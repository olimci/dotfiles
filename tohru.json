{
  "schema": 1,
  "requires": {
    "tohru": "0.2.0"
  },
  "profile": {
    "slug": "olimci-dotfiles",
    "name": "olimci dotfiles",
    "description": "my personal setup"
  },
  "hooks": [
    {
      "triggers": ["post_load", "post_reload", "post_unload"],
      "run": ["kitty", "@", "load-config"],
      "cwd": "home"
    }
  ],
  "roots": [
    {
      "source": "home",
      "dest": "~",
      "defaults": {
        "type": "link"
      },
      "tree": {
        ".config": {
          "atuin": {
            "config.toml": []
          },
          "bat": {
            "config": []
          },
          "fastfetch": {
            "config.jsonc": []
          },
          "git": {
            "ignore": []
          },
          "kitty": {
            "fonts.conf": [],
            "kitty.app.png": ["copy"],
            "kitty.conf": [],
            "ssh": {
              "remote-zsh": {
                "zshenv": ["copy"],
                "zshrc": ["copy"],
                "starship.toml": ["copy"]
              }
            },
            "ssh.conf": [],
            "theme.conf": []
          },
          "nvim": {
            "init.lua": [],
            "lazy-lock.json": []
          },
          "starship.toml": [],
          "yazi": {
            "yazi.toml": []
          },
          "zed": {
            "settings.json": []
          }
        },
        ".gitconfig": ["copy"],
        ".hushlogin": ["copy"],
        ".zshrc": ["copy"]
      }
    }
  ]
}
