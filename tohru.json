{
  "schema": 1,
  "requires": {
    "tohru": "0.2.0"
  },
  "profile": {
    "slug": "olimci-dotfiles",
    "name": "olimci dotfiles",
    "description": "my personal setup"
  },
  "hooks": [
    {
      "triggers": ["post_load", "post_reload", "post_unload"],
      "run": ["kitty", "@", "load-config"],
      "cwd": "home"
    }
  ],
  "roots": [
    {
      "source": "home",
      "dest": "~",
      "defaults": {
        "type": "link"
      },
      "tree": {
        ".config": {
          ".assets": {
            "sl": []
          },
          "bat": {
            "config": []
          },
          "fastfetch": {
            "config.jsonc": [],
            "small.jsonc": []
          },
          "git": {
            "ignore": []
          },
          "kitty": {
            "fonts.conf": [],
            "kitty.app.png": ["copy"],
            "kitty.conf": [],
            "ssh": {
              "zshenv": ["copy"],
              "zshrc": ["copy"],
              "starship.toml": ["copy"]
            },
            "ssh.conf": [],
            "theme.conf": []
          },
          "nvim": {
            "init.lua": [],
            "lazy-lock.json": []
          },
          "sketchybar": {
            "bar.lua": [],
            "colors.lua": [],
            "default.lua": [],
            "icons.lua": [],
            "init.lua": [],
            "items": {
              "calendar.lua": [],
              "front_app.lua": [],
              "init.lua": [],
              "media.lua": [],
              "spaces.lua": [],
              "widgets": {
                "battery.lua": [],
                "init.lua": [],
                "volume.lua": []
              }
            },
            "settings.lua": [],
            "sketchybarrc": []
          },
          "starship.toml": [],
          "zed": {
            "settings.json": []
          }
        },
        ".gitconfig": ["copy"],
        ".hushlogin": ["copy"],
        ".zshenv": ["copy"],
        ".zshrc": ["copy"]
      }
    }
  ]
}
