{
  "schema": 1,
  "requires": {
    "tohru": "0.2.0"
  },
  "profile": {
    "slug": "olimci-dotfiles",
    "name": "olimci dotfiles",
    "description": "my personal setup"
  },
  "hooks": [
    {
      "triggers": ["post_load", "post_reload", "post_unload"],
      "run": ["kitty", "@", "load-config"],
      "cwd": "home"
    }
  ],
  "roots": [
    {
      "source": "home",
      "dest": "~",
      "defaults": {
        "type": "link"
      },
      "tree": {
        ".codex": {
          "AGENTS.md": ["copy"],
          "rules": {
            "default.rules": ["copy"]
          },
          "pets": {
            ".": ["untracked"]
          }
        },
        ".config": {
          "atuin": {
            "config.toml": []
          },
          "bat": {
            "config": []
          },
          "fastfetch": {
            "config.jsonc": []
          },
          "git": {
            "ignore": []
          },
          "kitty": {
            "fonts.conf": [],
            "kitty.app.png": ["copy"],
            "kitty.conf": [],
            "ssh": {
              "remote-zsh": {
                "zshenv": ["copy"],
                "zshrc": ["copy"],
                "starship.toml": ["copy"]
              }
            },
            "ssh.conf": [],
            "theme.conf": []
          },
          "nvim": {
            "init.lua": [],
            "lazy-lock.json": []
          },
          "starship.toml": [],
          "yazi": {
            "yazi.toml": []
          },
          "zed": {
            "settings.json": []
          }
        },
        "Library": {
          "Application Support": {
            "Anki2": {
              "addons21": {
                "1046608507": {
                  "config.json": ["copy"]
                },
                "2055492159": {
                  "config.json": ["copy"]
                },
                "688199788": {
                  "config.json": ["copy"]
                }
              }
            },
            "nushell": {
              "config.nu": [],
              "env.nu": []
            }
          }
        },
        "Scripts": {
          "video-dl.sh": ["copy"],
          "tohru_reload": []
        },
        ".gitconfig": ["copy"],
        ".hushlogin": ["copy"],
        ".zshrc": ["copy"]
      }
    }
  ]
}
